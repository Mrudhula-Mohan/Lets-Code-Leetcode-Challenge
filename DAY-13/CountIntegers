class Solution(object):
    def countEven(self, num):
        """
        :type num: int
        :rtype: int
        """
        count=0
        for i in range(1,num+1):
            j=0
            n=i
            while n>0:
                j+=n%10
                n=n//10
            if j%2==0:
                 count+=1
        return count
