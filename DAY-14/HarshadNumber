class Solution(object):
    def sumOfTheDigitsOfHarshadNumber(self, x):
        """
        :type x: int
        :rtype: int
        """
        s = 0
        n = x
        
        while n > 0:
            s += n % 10
            n //= 10
        
        if x % s == 0:
            return s
        else:
            return -1
